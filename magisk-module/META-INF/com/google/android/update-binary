#!/sbin/sh

#################
# Initialization
#################

umask 022

# echo before loading util_functions
ui_print() { echo "$1"; }

require_new_magisk() {
  [ -f /data/adb/magisk/util_functions.sh ] || return 0
  . /data/adb/magisk/util_functions.sh
  [ "$MAGISK_VER_CODE" -lt 20400 ] && return 0
  return 1
}

#########################
# Load util_functions.sh
#########################

OUTFD=$2
ZIPFILE=$3

mount /data 2>/dev/null

if [ ! -f /data/adb/magisk/util_functions.sh ]; then
  if [ -f /data/adb/ksu/bin/busybox ]; then
    export PATH=/data/adb/ksu/bin:$PATH
  fi
fi

[ -f /data/adb/magisk/util_functions.sh ] && . /data/adb/magisk/util_functions.sh
[ -f /data/adb/ksu/bin/util_functions.sh ] && . /data/adb/ksu/bin/util_functions.sh

# Dummy functions for KernelSU compatibility
ui_print() {
  if [ -n "$OUTFD" ]; then
    echo "ui_print $1" >&$OUTFD
    echo "ui_print" >&$OUTFD
  else
    echo "$1"
  fi
}

abort() {
  ui_print "$1"
  exit 1
}

print() { ui_print "$1"; }

set_perm() {
  chown $2:$3 $1 || return 1
  chmod $4 $1 || return 1
  [ -z $5 ] && return 0
  chcon $5 $1 2>/dev/null || return 0
}

set_perm_recursive() {
  find $1 -type d 2>/dev/null | while read dir; do
    set_perm $dir $2 $3 $5 $6
  done
  find $1 -type f 2>/dev/null | while read file; do
    set_perm $file $2 $3 $4 $6
  done
}

##############
# Environment
##############

# KernelSU detection
KSU=false
if [ -z $MAGISK_VER_CODE ] && [ -f /data/adb/ksu/bin/busybox ]; then
  KSU=true
  MAGISK_VER_CODE=25200
  MAGISK_VER=v25.2
fi

# Set up module installation directory
if [ -z $MODPATH ]; then
  MODPATH=/data/adb/modules/$MODID
fi

# Default MODID if not set
if [ -z $MODID ]; then
  MODID=$(basename $MODPATH)
fi

# Create module directory
mkdir -p $MODPATH

# Extract module files
cd $MODPATH
unzip -o "$ZIPFILE" -x "META-INF/*" >/dev/null 2>&1

# Source customize.sh if exists
if [ -f $MODPATH/customize.sh ]; then
  . $MODPATH/customize.sh
fi

# Set default permissions
set_perm_recursive $MODPATH 0 0 0755 0644

ui_print "- Installation complete"
